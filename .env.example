# AssetFlow environment variables

# Backend
APP_NAME=AssetFlow
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/assetflow

# Authentication
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
